# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/weddingclouds

# JWT — generate a strong random secret for production
JWT_SECRET=change-this-to-a-long-random-string

# Initial owner account (used only on first run when the DB is empty)
OWNER_EMAIL=yourname@gmail.com
OWNER_PASSWORD=your-secure-password
OWNER_NAME=Your Name

# SMTP email (optional — quotes will still work without it, emails are skipped)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=yourname@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=yourname@gmail.com
